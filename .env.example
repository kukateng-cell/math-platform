# Session JWT 簽章密鑰（jose HS256）
SESSION_SECRET=change-me-to-a-long-random-string

# OTP HMAC 專用金鑰（與 SESSION_SECRET 隔離，建議獨立隨機字串）
# 若未設定，會從 SESSION_SECRET 衍生出不同金鑰（使用不同 prefix）。
# 產生方式：openssl rand -base64 32
# OTP_SECRET=change-me-to-another-random-string

# Supabase PostgreSQL 連線字串
# 取得方式：Supabase 專案 → Project Settings → Database → Connection string → URI
#
# 🔑 兩種連線模式（port 不同）：
#
# 1) Direct connection（port 5432）→ 給 prisma migrate / db push / seed 用（CLI）
#    postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].supabase.com:5432/postgres
#
# 2) Pooled connection（port 6543）→ 給 runtime（Server Actions）用
#    postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
#
# 簡化做法：開發階段兩者都用同一條 pooled 字串（port 6543）即可。
# 本專案目前 prisma.config.ts 與 src/lib/prisma.ts 都讀 DATABASE_URL，
# 所以填一條即可。生產環境建議分開（DIRECT_URL 給 migrate）。
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres"

# （選用）給 prisma migrate 的非 pooled 連線
# DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].supabase.com:5432/postgres"

# ===== Gmail SMTP（寄送 OTP 驗證碼）=====
# 使用 Gmail 的 SMTP 伺服器寄送 6 位數驗證碼。
# ⚠️ 必須產生「應用程式密碼」，不能用 Gmail 密碼！
#
# 產生方式：
#   1. 開啟 https://myaccount.google.com/security
#   2. 開啟「兩步驟驗證」
#   3. 到底下「應用程式密碼」產生一組 16 位數密碼（選「其他」→ 自訂名稱）
#   4. 複製那組密碼填入 SMTP_PASS
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-16-digit-app-password
# SMTP_FROM=your-email@gmail.com

# ===== 管理員密碼（seed 建立 admin 帳號用）=====
# 正式環境強烈建議設定一組強密碼（至少 8 碼，且不可為 admin123）。
# 未設定或為弱密碼時，正式環境 seed 會自動產生一次性隨機密碼並印在終端機。
# 開發環境若未設定，則預設為 admin123（僅限本機測試）。
# ADMIN_PASSWORD=set-a-strong-password-here
