// Prisma 7: datasource 不可寫 url，連線字串改放 prisma.config.ts
// runtime PrismaClient 必須傳入 driver adapter (見 lib/prisma.ts)

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============ 帳號 ============

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         Role     @default(PARENT)
  // tokenVersion 用於 session 失效：JWT 內嵌此版本，驗證時對比 DB。
  // 變更角色（升級/降級 admin）時遞增，使所有舊 session 立即失效。
  tokenVersion Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  childProfiles ChildProfile[]
  childLinks    ParentChild[]  @relation("ParentLinks")
  sessions      PracticeSession[]
  // 密碼重設授權（OTP 通過後簽發，一次性，綁定 tokenVersion 防重放）
  passwordResetGrants PasswordResetGrant[]

  @@index([email])
}

enum Role {
  PARENT
  ADMIN
}

enum GradeLevel {
  K
  G1
  G2
  G3
  G4
  G5
  G6
}

enum PracticeStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ABANDONED
}

enum PracticeKind {
  NORMAL
  PROMOTION
  CHALLENGE
}

// ============ 親子關聯（學生可主動綁定家長，家長也可綁定學生）============
// 安全：學生主動綁定家長時，先建立 PENDING 記錄並通知家長，
//       家長須在後台「確認」後才會變成 ACTIVE（家長才看得到該孩子資料）。
//       家長自己建立的孩子其 parentId 直接寫在 ChildProfile 上（不走此表）。
model ParentChild {
  id        String     @id @default(cuid())
  parentId  String
  childId   String
  status    LinkStatus @default(ACTIVE)
  createdAt DateTime   @default(now())

  parent User          @relation("ParentLinks", fields: [parentId], references: [id], onDelete: Cascade)
  child  ChildProfile  @relation("ChildLinks", fields: [childId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId])
  @@index([parentId])
  @@index([childId])
  @@index([status])
}

enum LinkStatus {
  PENDING // 學生已送出綁定請求，等待家長確認
  ACTIVE  // 家長已確認（或系統建立的既有資料），關聯生效
}

// ============ 孩子檔案 / 學生帳號 ============

model ChildProfile {
  id        String   @id @default(cuid())
  // 學生可以有自己的帳號獨立登入（Email OTP，免密碼）
  email     String?  @unique
  nickname  String
  gradeLevel GradeLevel  // K, G1, G2 ...

  // 可選：由家長建立時才有 parentId；學生自主註冊時為 null
  parentId  String?
  // 學習模式：STANDARD(可綁家長) | SELF_STUDY(用驗證碼登入,自主學習)
  mode      ChildMode @default(STANDARD)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ============ 遊戲化 ============
  stars          Int       @default(0)   // 累計星星數
  streak         Int       @default(0)   // 連續練習天數
  lastPracticeAt DateTime?               // 上次練習日期（供 streak 計算）
  promotionCount Int       @default(0)   // 升學通過次數（供 promotion-star 徽章計算）

  // ============ 升學追蹤（P1-9：防重複獎勵 race condition）============
  promotionPassedAt  DateTime?  // 最後一次通過升學測試的時間
  promotionTarget    GradeLevel?    // 通過的目標年級
  promotionRewarded  Boolean    @default(false)  // 是否已發放升學獎勵

  parent            User?             @relation(fields: [parentId], references: [id], onDelete: Cascade)
  parentLinks       ParentChild[]     @relation("ChildLinks")
  masterySnapshots  MasterySnapshot[]
  sessions          PracticeSession[]
  badges            ChildBadge[]

  @@index([parentId])
  @@index([email])
}

enum ChildMode {
  STANDARD   // 可綁家長
  SELF_STUDY // 用驗證碼登入,自主學習
}

// ============ 技能 ============

model Skill {
  id          String    @id @default(cuid())
  code        String    @unique // e.g. "count-compare", "add-within-10"
  name        String
  description String?
  gradeLevel  GradeLevel // K, G1, G2（enum 校驗）
  order       Int      @default(0)
  // 前置技能（可選），規則式推薦用
  prerequisiteId String?
  prerequisite   Skill?  @relation("SkillPrereq", fields: [prerequisiteId], references: [id])
  dependents     Skill[] @relation("SkillPrereq")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  questions         QuestionTemplate[]
  masterySnapshots  MasterySnapshot[]
  sessions          PracticeSession[]

  @@index([prerequisiteId])
  @@index([gradeLevel])
  @@unique([gradeLevel, order])
}

// ============ 題目模板 ============

model QuestionTemplate {
  id         String   @id @default(cuid())
  skillId    String
  // 題型：直接題目 或 參數化模板
  type       QuestionType
  // 題目文字（直接題目用），或模板說明
  prompt     String
  // 參數化題目用：JSON 定義範圍，例如 {"aMin":0,"aMax":5,"bMin":1,"bMax":5}
  paramsJson String?
  // 正確答案（直接題目用），或答案計算邏輯
  answer     String
  // 選項（選擇題用），逗號分隔；為空表示填答題
  options    String?
  // 解題說明（作答後顯示，不可在作答前送到瀏覽器）
  explanation String?
  // 作答前提示（不含答案，可安全顯示；查看後該題自動視為 assisted）
  hint       String?
  isActive   Boolean  @default(true)
  // 提升練習題：跨技能綜合應用題，難度較高，不影響掌握度與升學
  isChallenge Boolean @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)
  attempts Attempt[]

  @@index([skillId])
}

enum QuestionType {
  DIRECT       // 直接題目
  ADD          // 參數化加法
  SUB          // 參數化減法
  WORD_PROBLEM // 參數化生活情境文字題
  MUL          // 參數化乘法
  DIV          // 參數化除法
}

// ============ 練習 ============

model PracticeSession {
  id         String         @id @default(cuid())
  childId    String
  skillId    String
  parentId   String?
  status     PracticeStatus @default(IN_PROGRESS)
  kind       PracticeKind   @default(NORMAL)
  startedAt  DateTime       @default(now())
  completedAt DateTime?
  cancelledAt DateTime?
  abandonedAt DateTime?
  totalQuestions Int         @default(0)
  correctCount   Int         @default(0)
  // P2-4：非 assisted 的答題數（正確率分母用），避免 assisted 題被當成錯題
  gradedQuestionCount Int @default(0)
  // P2-4：assisted（家長協助）的答題數
  assistedCount      Int @default(0)
  // 伺服器生成的題目快照（JSON），供 submitAnswer 驗證用，避免信任前端
  questionsJson String?

  child    ChildProfile     @relation(fields: [childId], references: [id], onDelete: Cascade)
  skill    Skill            @relation(fields: [skillId], references: [id])
  parent   User?            @relation(fields: [parentId], references: [id])
  attempts Attempt[]

  @@index([childId])
  @@index([skillId])
}

model Attempt {
  id          String   @id @default(cuid())
  sessionId   String
  // P1-7：questionId 改為可空。題目模板被刪除（soft delete → isActive=false）時，
  // Attempt 仍可保留，questionId 設為 null，歷史資料不遺失。
  questionId  String?
  // 題目在 session 中的索引（0-based），配合唯一約束防止同一題重複提交
  questionIndex Int     @default(0)
  // 保存作答當下的題目快照（避免題目修改影響歷史紀錄）
  questionPrompt String
  userAnswer  String
  correctAnswer String
  isCorrect   Boolean
  assisted    Boolean  @default(false) // 家長協助
  durationMs  Int      @default(0)
  createdAt   DateTime @default(now())

  session  PracticeSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question QuestionTemplate?   @relation(fields: [questionId], references: [id], onDelete: SetNull)

  @@unique([sessionId, questionIndex]) // 防止同一題重複提交刷星星/掌握度
  @@index([sessionId])
  @@index([questionId])
}

// ============ 掌握度 ============

model MasterySnapshot {
  id           String   @id @default(cuid())
  childId      String
  skillId      String
  // 最近 N 題的統計快照，供規則式推薦
  recentCorrect Int     @default(0)
  recentTotal   Int     @default(0)
  masteryLevel  Float   @default(0) // 0-1
  updatedAt    DateTime @updatedAt

  child ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
  skill Skill        @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([childId, skillId])
  @@index([childId])
}

// ============ 成就徽章 ============

model Badge {
  id        String   @id @default(cuid())
  code      String   @unique // e.g. "first-practice", "streak-7"
  name      String
  icon      String   // emoji
  condition String   // 解鎖條件描述
  isActive  Boolean  @default(true) // P2-13：停用而非刪除，保留歷史徽章

  childBadges ChildBadge[]
}

model ChildBadge {
  id        String   @id @default(cuid())
  childId   String
  badgeId   String
  earnedAt  DateTime @default(now())

  child ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
  badge Badge       @relation(fields: [badgeId], references: [id])

  @@unique([childId, badgeId])
  @@index([childId])
}

// ============ OTP 驗證碼（替代記憶體 Map，serverless 可靠）============
// 用途：家長登入/忘記密碼的 Email OTP。以 identifier 為 key（通常是 userId）。
// 冷卻與過期由 expiresAt / resentAt 欄位控制，verifyOtp 成功後刪除（一次性）。
model OtpCode {
  id         String    @id @default(cuid())
  identifier String    // 通常是 userId，忘記密碼場景也用 userId
  code       String    // OTP 的 HMAC-SHA256 hash（含 identifier），不存明文
  expiresAt  DateTime  // OTP 有效期限（產生後 5 分鐘）
  resentAt   DateTime  // 上次發送時間（用於 60 秒冷卻判斷）
  // P1-1：OTP 錯誤嘗試次數與鎖定時間
  attemptCount Int      @default(0)
  lockedAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([identifier])
  @@index([expiresAt])
}

// ============ 密碼重設授權（PasswordResetGrant）============
// 用途：忘記密碼 OTP 驗證通過後簽發的「可重設密碼」授權紀錄。
// 安全：
//   1. 一次性（consumedAt）：resetPassword 成功後標記為已消耗，
//      同一 token 無法再次使用（防重放）。
//   2. tokenVersion 比對：grant 建立時快照 user.tokenVersion，
//      resetPassword 時若 user.tokenVersion 已變動（如另一次重設、
//      角色變更）則此 grant 視為過期，必須重新驗證 OTP。
//   3. 一次重設作廢所有 outstanding grants：成功重設後以 updateMany
//      將該 user 所有 consumedAt=null 的 grant 一次標記為已消耗，
//      防止「先後兩次 OTP → 兩個 grant → 第一個用完第二個還能用」。
model PasswordResetGrant {
  id           String    @id @default(cuid())
  userId       String
  tokenVersion Int       // 簽發當下 User.tokenVersion 的快照
  consumedAt   DateTime? // null = 尚未使用；重設成功後填入時間
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([consumedAt])
}

// ============ 登入/操作限速（替代記憶體 Map，serverless 可靠）============
// 用途：同一 key（email、userId 等）在時間窗口內的操作次數限制。
// key 設計為帶前綴的複合字串，如 "login:alice@example.com"、"reset:bob@example.com"。
model RateLimit {
  id        String   @id @default(cuid())
  key       String   @unique // 限速唯一鍵（含場景前綴）
  count     Int      @default(0)
  resetAt   DateTime // 窗口重置時間
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

// ============ 註冊暫存（PendingSignup）============
// 用途：家長註冊流程中，CAPTCHA + OTP 驗證期間暫存註冊資料。
// OTP 驗證通過後建立 User，並刪除此暫存記錄。自動過期（expiresAt）。
model PendingSignup {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  attemptCount Int      @default(0)
  expiresAt    DateTime // 建立後 10 分鐘自動過期
  createdAt    DateTime @default(now())

  @@index([expiresAt])
}
