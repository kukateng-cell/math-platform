// Prisma 7: datasource 不可寫 url，連線字串改放 prisma.config.ts
// runtime PrismaClient 必須傳入 driver adapter (見 lib/prisma.ts)

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============ 帳號 ============

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         Role     @default(PARENT)
  // tokenVersion 用於 session 失效：JWT 內嵌此版本，驗證時對比 DB。
  // 變更角色（升級/降級 admin）時遞增，使所有舊 session 立即失效。
  tokenVersion Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  childProfiles ChildProfile[]
  childLinks    ParentChild[]  @relation("ParentLinks")
  sessions      PracticeSession[]

  @@index([email])
}

enum Role {
  PARENT
  ADMIN
}

enum GradeLevel {
  K
  G1
  G2
  G3
  G4
  G5
  G6
}

enum PracticeStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ABANDONED
}

enum PracticeKind {
  NORMAL
  PROMOTION
  CHALLENGE
}

// ============ 親子關聯（學生可主動綁定家長，家長也可綁定學生）============
// 安全：學生主動綁定家長時，先建立 PENDING 記錄並通知家長，
//       家長須在後台「確認」後才會變成 ACTIVE（家長才看得到該孩子資料）。
//       家長自己建立的孩子其 parentId 直接寫在 ChildProfile 上（不走此表）。
model ParentChild {
  id        String     @id @default(cuid())
  parentId  String
  childId   String
  status    LinkStatus @default(ACTIVE)
  createdAt DateTime   @default(now())

  parent User          @relation("ParentLinks", fields: [parentId], references: [id], onDelete: Cascade)
  child  ChildProfile  @relation("ChildLinks", fields: [childId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId])
  @@index([parentId])
  @@index([childId])
  @@index([status])
}

enum LinkStatus {
  PENDING // 學生已送出綁定請求，等待家長確認
  ACTIVE  // 家長已確認（或系統建立的既有資料），關聯生效
}

// ============ 孩子檔案 / 學生帳號 ============

model ChildProfile {
  id        String   @id @default(cuid())
  // 學生可以有自己的帳號密碼獨立登入
  email        String?  @unique
  passwordHash String?
  pin          String?  // 4 位數 PIN 碼
  nickname     String
  gradeLevel   String  // K, G1, G2 ...（程式碼層驗證，見 grade.ts / definitions.ts）

  // 可選：由家長建立時才有 parentId；學生自主註冊時為 null
  parentId  String?
  // 學習模式：STANDARD(需 PIN,可綁家長) | SELF_STUDY(免 PIN,用驗證碼登入)
  mode      ChildMode @default(STANDARD)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ============ 遊戲化 ============
  stars          Int       @default(0)   // 累計星星數
  streak         Int       @default(0)   // 連續練習天數
  lastPracticeAt DateTime?               // 上次練習日期（供 streak 計算）

  // ============ 升學追蹤（P1-9：防重複獎勵 race condition）============
  promotionPassedAt  DateTime?  // 最後一次通過升學測試的時間
  promotionTarget    String?  // 通過的目標年級
  promotionRewarded  Boolean    @default(false)  // 是否已發放升學獎勵

  parent            User?             @relation(fields: [parentId], references: [id], onDelete: Cascade)
  parentLinks       ParentChild[]     @relation("ChildLinks")
  masterySnapshots  MasterySnapshot[]
  sessions          PracticeSession[]
  badges            ChildBadge[]

  @@index([parentId])
  @@index([email])
}

enum ChildMode {
  STANDARD   // 需 PIN,可綁家長
  SELF_STUDY // 免 PIN,用驗證碼登入,自主學習
}

// ============ 技能 ============

model Skill {
  id          String    @id @default(cuid())
  code        String    @unique // e.g. "count-compare", "add-within-10"
  name        String
  description String?
  gradeLevel  String // K, G1, G2（程式碼層驗證，見 grade.ts / definitions.ts）
  order       Int      @default(0)
  // 前置技能（可選），規則式推薦用
  prerequisiteId String?
  prerequisite   Skill?  @relation("SkillPrereq", fields: [prerequisiteId], references: [id])
  dependents     Skill[] @relation("SkillPrereq")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  questions         QuestionTemplate[]
  masterySnapshots  MasterySnapshot[]
  sessions          PracticeSession[]

  @@index([prerequisiteId])
  @@index([gradeLevel])
}

// ============ 題目模板 ============

model QuestionTemplate {
  id         String   @id @default(cuid())
  skillId    String
  // 題型：直接題目 或 參數化模板
  type       QuestionType
  // 題目文字（直接題目用），或模板說明
  prompt     String
  // 參數化題目用：JSON 定義範圍，例如 {"aMin":0,"aMax":5,"bMin":1,"bMax":5}
  paramsJson String?
  // 正確答案（直接題目用），或答案計算邏輯
  answer     String
  // 選項（選擇題用），逗號分隔；為空表示填答題
  options    String?
  explanation String?
  isActive   Boolean  @default(true)
  // 提升練習題：跨技能綜合應用題，難度較高，不影響掌握度與升學
  isChallenge Boolean @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)
  attempts Attempt[]

  @@index([skillId])
}

enum QuestionType {
  DIRECT       // 直接題目
  ADD          // 參數化加法
  SUB          // 參數化減法
  WORD_PROBLEM // 參數化生活情境文字題
  MUL          // 參數化乘法
  DIV          // 參數化除法
}

// ============ 練習 ============

model PracticeSession {
  id         String         @id @default(cuid())
  childId    String
  skillId    String
  parentId   String?
  status     PracticeStatus @default(IN_PROGRESS)
  kind       PracticeKind   @default(NORMAL)
  startedAt  DateTime       @default(now())
  completedAt DateTime?
  cancelledAt DateTime?
  abandonedAt DateTime?
  totalQuestions Int         @default(0)
  correctCount   Int         @default(0)
  // 伺服器生成的題目快照（JSON），供 submitAnswer 驗證用，避免信任前端
  questionsJson String?

  child    ChildProfile     @relation(fields: [childId], references: [id], onDelete: Cascade)
  skill    Skill            @relation(fields: [skillId], references: [id])
  parent   User?            @relation(fields: [parentId], references: [id])
  attempts Attempt[]

  @@index([childId])
  @@index([skillId])
}

model Attempt {
  id          String   @id @default(cuid())
  sessionId   String
  // P1-7：questionId 改為可空。題目模板被刪除（soft delete → isActive=false）時，
  // Attempt 仍可保留，questionId 設為 null，歷史資料不遺失。
  questionId  String?
  // 題目在 session 中的索引（0-based），配合唯一約束防止同一題重複提交
  questionIndex Int     @default(0)
  // 保存作答當下的題目快照（避免題目修改影響歷史紀錄）
  questionPrompt String
  userAnswer  String
  correctAnswer String
  isCorrect   Boolean
  assisted    Boolean  @default(false) // 家長協助
  durationMs  Int      @default(0)
  createdAt   DateTime @default(now())

  session  PracticeSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question QuestionTemplate?   @relation(fields: [questionId], references: [id], onDelete: SetNull)

  @@unique([sessionId, questionIndex]) // 防止同一題重複提交刷星星/掌握度
  @@index([sessionId])
  @@index([questionId])
}

// ============ 掌握度 ============

model MasterySnapshot {
  id           String   @id @default(cuid())
  childId      String
  skillId      String
  // 最近 N 題的統計快照，供規則式推薦
  recentCorrect Int     @default(0)
  recentTotal   Int     @default(0)
  masteryLevel  Float   @default(0) // 0-1
  updatedAt    DateTime @updatedAt

  child ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
  skill Skill        @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([childId, skillId])
  @@index([childId])
}

// ============ 成就徽章 ============

model Badge {
  id        String   @id @default(cuid())
  code      String   @unique // e.g. "first-practice", "streak-7"
  name      String
  icon      String   // emoji
  condition String   // 解鎖條件描述

  childBadges ChildBadge[]
}

model ChildBadge {
  id        String   @id @default(cuid())
  childId   String
  badgeId   String
  earnedAt  DateTime @default(now())

  child ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
  badge Badge       @relation(fields: [badgeId], references: [id])

  @@unique([childId, badgeId])
  @@index([childId])
}

// ============ OTP 驗證碼（替代記憶體 Map，serverless 可靠）============
// 用途：家長登入/忘記密碼的 Email OTP。以 identifier 為 key（通常是 userId）。
// 冷卻與過期由 expiresAt / resentAt 欄位控制，verifyOtp 成功後刪除（一次性）。
model OtpCode {
  id         String    @id @default(cuid())
  identifier String    // 通常是 userId，忘記密碼場景也用 userId
  code       String    // OTP 的 HMAC-SHA256 hash（含 identifier），不存明文
  expiresAt  DateTime  // OTP 有效期限（產生後 5 分鐘）
  resentAt   DateTime  // 上次發送時間（用於 60 秒冷卻判斷）
  // P1-1：OTP 錯誤嘗試次數與鎖定時間
  attemptCount Int      @default(0)
  lockedAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([identifier])
  @@index([expiresAt])
}

// ============ 註冊暫存（替代記憶體 Map，serverless 可靠）============
// 用途：家長註冊 Step 1（填寫資料）→ Step 2（驗證 OTP）之間的資料暫存。
// 用 JWT tempToken 攜帶 pendingSignupId，避免在多個 serverless instance 間共享。
// OTP 驗證成功後自動刪除，或由 expiresAt 定期清理。
model PendingSignup {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  // 嘗試次數：超過 maxAttempts 後自動刪除（防暴力破解 OTP）
  attemptCount Int      @default(0)
  expiresAt    DateTime // 有效期限（產生後 10 分鐘）
  createdAt    DateTime @default(now())

  @@index([expiresAt])
}

// ============ 密碼重設授權（一次性 grant，防 token 重放）============
// 用途：忘記密碼 OTP 驗證通過後，產生一筆 grant（帶 jti）存入 DB，
// 並簽發帶相同 jti 的 PASSWORD_RESET_VERIFIED token。
// resetPassword 必須在 transaction 中「消耗」此 grant（consumedAt 從 null 設為時間戳），
// 確保即使 token 被 replay，也只有第一次能成功。consumedAt IS NULL 的條件式
// updateMany 即為 idempotency gate。
model PasswordResetGrant {
  id         String    @id @default(cuid())
  userId     String
  // JWT ID：與 PASSWORD_RESET_VERIFIED token 內的 jti 對應，一次性消耗
  jti        String    @unique
  // null = 尚未使用；resetPassword 成功時設為時間戳
  consumedAt DateTime?
  // 與 token 同步過期（產生後 10 分鐘），過期的 grant 可定期清理
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ============ 登入/操作限速（替代記憶體 Map，serverless 可靠）============
// 用途：同一 key（email、userId 等）在時間窗口內的操作次數限制。
// key 設計為帶前綴的複合字串，如 "login:alice@example.com"、"reset:bob@example.com"。
model RateLimit {
  id        String   @id @default(cuid())
  key       String   @unique // 限速唯一鍵（含場景前綴）
  count     Int      @default(0)
  resetAt   DateTime // 窗口重置時間
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}
